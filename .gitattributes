# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.astro text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mdx text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# License files
LICENSE text eol=lf
LICENSE-* text eol=lf

# Config files
.gitignore text eol=lf
.gitattributes text eol=lf

# JavaScript modules
*.mjs text eol=lf
*.cjs text eol=lf

# Lyrics
*.lrc text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.webp binary
*.ico binary
*.mp3 binary
*.wav binary
*.ogg binary
*.flac binary
